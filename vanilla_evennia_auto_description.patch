+import random
+
+
+PERIOD_MATERIALS = [
+    "timber-framed walls",
+    "lime-washed plaster",
+    "weathered stonework",
+    "oak beams darkened by smoke",
+    "patched masonry",
+]
+
+PERIOD_STREET_DETAILS = [
+    "cart-rutted earth lies underfoot",
+    "cobbles shine where generations of traffic have polished them smooth",
+    "rainwater gathers in shallow seams between worn stones",
+    "the lane narrows between close-built walls and jutting upper stories",
+]
+
+PERIOD_SOUNDS = [
+    "Distant trade calls drift through the air.",
+    "The creak of wagon wheels and the echo of footsteps carry down the street.",
+    "Muted voices leak from nearby doors and shuttered windows.",
+    "Somewhere nearby, iron strikes wood with a hollow working rhythm.",
+]
+
+PERIOD_MARKET_DETAILS = [
+    "Canvas awnings and crowded stalls suggest a district built around trade.",
+    "The smell of barter, produce, cloth, and dust hangs lightly in the air.",
+    "Nearby shopfronts and open counters make the street feel brisk and busy.",
+]
+
+PERIOD_DOCKSIDE_DETAILS = [
+    "Tar, rope, and damp timber suggest a quarter close to the water.",
+    "The stonework shows salt stains and hard use from labor near the docks.",
+    "Everything here feels a little wetter, older, and more hard-worked.",
+]
+
+PERIOD_CIVIC_DETAILS = [
+    "Cut stone facades and straighter lines give the place a more official character.",
+    "Posted notices, orderly walls, and better-kept paving hint at civic oversight.",
+    "The district feels more deliberate here, built to be seen and remembered.",
+]
+
+PERIOD_ALLEY_DETAILS = [
+    "The close press of walls and shadow makes the passage feel more private than public.",
+    "Narrow sightlines and back-door traffic give the place a furtive character.",
+    "The way feels tighter here, with sound carrying strangely between the walls.",
+]
+
+
+def _detail_bank_for_zone(zone_name):
+    lower = (zone_name or "").lower()
+    if any(token in lower for token in ("dock", "wharf", "harbor", "river")):
+        return PERIOD_DOCKSIDE_DETAILS
+    if any(token in lower for token in ("market", "bazaar", "trade", "merchant")):
+        return PERIOD_MARKET_DETAILS
+    if any(token in lower for token in ("civic", "court", "hall", "square", "temple")):
+        return PERIOD_CIVIC_DETAILS
+    if any(token in lower for token in ("alley", "lane", "crook", "cut")):
+        return PERIOD_ALLEY_DETAILS
+    return PERIOD_STREET_DETAILS
+
+
+def build_room_description(room_key, zone_name="the district", seed_text=""):
+    seed = f"{room_key}|{zone_name}|{seed_text}"
+    rng = random.Random(seed)
+
+    material = rng.choice(PERIOD_MATERIALS)
+    street = rng.choice(PERIOD_STREET_DETAILS)
+    sound = rng.choice(PERIOD_SOUNDS)
+    district_detail = rng.choice(_detail_bank_for_zone(zone_name))
+
+    return (
+        f"{room_key} lies within {zone_name}, marked by {material}. "
+        f"Here, {street}. {district_detail} {sound}"
+    )